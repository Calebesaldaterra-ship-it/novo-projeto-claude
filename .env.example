# ─────────────────────────────────────────
# Anthropic — cérebro do assistente de voz (Jarvis da Lux Vision)
# Pegar em: console.anthropic.com → API Keys (precisa de créditos)
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=
# Opcionais do assistente de voz (Aslam):
# ASSISTENTE_MODELO=claude-sonnet-5
# ASSISTENTE_PORTA=5173
#
# Cérebro GRÁTIS local (Ollama) — deixe ANTHROPIC_API_KEY vazio pra usar,
# ou force com ASSISTENTE_BACKEND=ollama. Precisa do Ollama instalado + modelo baixado.
# ASSISTENTE_BACKEND=ollama
# OLLAMA_MODELO=llama3.2
# OLLAMA_URL=http://localhost:11434

# ─────────────────────────────────────────
# Cloudinary — hospedagem de imagens
# Pegar em: cloudinary.com → Dashboard
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─────────────────────────────────────────
# Meta Graph API — Instagram + Facebook
# Pegar seguindo: marketing/automacao-meta-setup.md
# ─────────────────────────────────────────
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=

# ─────────────────────────────────────────
# Site (usado por /aprovar-post)
# Preencher após hospedar a landing page
# ─────────────────────────────────────────
SITE_URL=https://
